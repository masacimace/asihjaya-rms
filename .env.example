# Aplikasi
NEXT_PUBLIC_APP_NAME=Asihjaya Retail Management System
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Organization yang digunakan pada halaman login internal
DEFAULT_ORGANIZATION_SLUG=asihjaya

# Database lokal melalui Docker Compose
DATABASE_URL=postgresql://asihjaya:asihjaya_dev@localhost:5432/asihjaya_rms

# Gunakan random secret minimal 32 karakter.
# Jangan gunakan value contoh ini untuk staging/production.
SESSION_SECRET="change-me-32-karakter"

# Secret komunikasi Cloud VPS <-> Asihjaya Hardware Hub.
# Harus sama dengan HUB_SECRET pada hardware-hub/.env.
# Gunakan random secret minimal 32 karakter untuk production.
HARDWARE_HUB_SECRET="local-dev-hardware-secret-please-change"

# Hardware job auto-recovery.
# Job claimed/printing yang tidak update melebihi nilai ini dianggap macet.
HARDWARE_JOB_STALE_MINUTES=10

# Hardware job cleanup & retention.
# Cleanup hanya menghapus job terminal lama: completed, cancelled, failed.
HARDWARE_JOB_COMPLETED_RETENTION_DAYS=30
HARDWARE_JOB_CANCELLED_RETENTION_DAYS=30
HARDWARE_JOB_FAILED_RETENTION_DAYS=90

#Default stale agent threshold=5 menit
HARDWARE_AGENT_STALE_MINUTES=5

# Konfigurasi Shift Cash Variance. Gunakan nilai default.
SHIFT_CASH_VARIANCE_CRITICAL_AMOUNT=100000
LARGE_CASH_OUT_NOTIFICATION_AMOUNT=1000000

# Bootstrap organization
BOOTSTRAP_ORGANIZATION_NAME=Asihjaya
BOOTSTRAP_ORGANIZATION_SLUG=asihjaya

# Bootstrap outlet
BOOTSTRAP_OUTLET_CODE=UTAMA
BOOTSTRAP_OUTLET_NAME=Outlet Utama

# Bootstrap register
BOOTSTRAP_REGISTER_CODE=POS-01
BOOTSTRAP_REGISTER_NAME=Kasir Utama

# Bootstrap administrator - development only. Ganti sebelum staging/production.
BOOTSTRAP_ADMIN_NAME=System Administrator
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@asihjaya.local
BOOTSTRAP_ADMIN_PASSWORD=asihjaya-retail@2026

# Penyimpanan foto. Gunakan local saat development dan s3 saat staging/production.
IMAGE_STORAGE_DRIVER=local
IMAGE_STORAGE_ROOT=.data/uploads
IMAGE_MAX_UPLOAD_MB=5

# Konfigurasi S3-compatible (Cloudflare R2, Backblaze B2, atau AWS S3).
# Aktifkan dengan IMAGE_STORAGE_DRIVER=s3. Jangan commit credential asli.
IMAGE_STORAGE_BUCKET=
IMAGE_STORAGE_ENDPOINT=
IMAGE_STORAGE_REGION=auto
IMAGE_STORAGE_ACCESS_KEY_ID=
IMAGE_STORAGE_SECRET_ACCESS_KEY=
IMAGE_STORAGE_FORCE_PATH_STYLE=false

# Reserved untuk phase berikutnya. Jangan isi credential asli di file example.
# MIDTRANS_ENVIRONMENT=sandbox
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_MERCHANT_ID=
# MIDTRANS_WEBHOOK_SECRET=
# WHATSAPP_CLOUD_API_VERSION=v20.0
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=

# Hardware agent bootstrap script.
# Jalankan dengan: npm run hardware:agent:create
# HARDWARE_AGENT_ORGANIZATION_SLUG=asihjaya
# HARDWARE_AGENT_OUTLET_CODE=UTAMA
# HARDWARE_AGENT_REGISTER_CODE=POS-01
# HARDWARE_AGENT_CODE=hub-utama-pos-01
# HARDWARE_AGENT_NAME=Mini PC Kasir Utama
# HARDWARE_AGENT_SECRET=asihjaya-local-agent-secret-1234567890

# Hardware Hub operational hardening note:
# Agent lokal punya REQUEST_TIMEOUT_MS dan PRINT_COMMAND_TIMEOUT_MS di hardware-hub/.env.
# Server menolak duplikat active job untuk source/job type yang sama tanpa perlu env tambahan.
