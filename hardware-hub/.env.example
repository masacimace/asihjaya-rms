# URL web app Asihjaya RMS di cloud/VPS.
# Local dev: http://localhost:3000
# Production wajib HTTPS: https://app.asihjaya.com
ASIHJAYA_API_URL=http://localhost:3000

# Dibuat dari root web app dengan:
# npm run hardware:agent:create
HARDWARE_AGENT_ID=cd5a598a-69fe-4d78-bf85-4a819c24715d
HARDWARE_AGENT_SECRET=asihjaya-local-agent-secret-1234567890

# Rollout protocol:
# v2-preferred = recover/claim v2 dahulu, lalu fallback ke job v1 jika queue v2 kosong.
# v2-only      = hanya Protocol v2.
# v1-only      = compatibility mode tanpa SQLite execution journal.
HARDWARE_PROTOCOL_MODE=v2-preferred

# SQLite execution journal. Path relatif terhadap folder hardware-hub.
HARDWARE_JOURNAL_PATH=./data/hardware-executions.sqlite
HARDWARE_JOURNAL_KEY_PATH=./data/hardware-journal.key
# Windows default. Ubah hanya jika PowerShell berada pada path lain.
HARDWARE_POWERSHELL_EXECUTABLE=powershell.exe
HARDWARE_TEMP_DIR=./data/temp
LEASE_RENEW_INTERVAL_MS=20000
LOCAL_RECOVERY_LIMIT=50

# Adapter hardware:
# real = kirim ke printer/drawer Windows.
# fake = tetap menjalankan lifecycle v2, tetapi menulis artifact file tanpa hardware fisik.
HARDWARE_ADAPTER_MODE=fake
LABEL_PRINTER_ADAPTER=fake
DOCUMENT_PRINTER_ADAPTER=fake
CASH_DRAWER_ADAPTER=fake

# Compatibility lama. HARDWARE_DRY_RUN=true dipetakan menjadi adapter fake,
# tetapi konfigurasi adapter di atas lebih disarankan.
HARDWARE_DRY_RUN=false
DRY_RUN_OUTPUT_DIR=./dry-run-output

# Failure injection untuk development tanpa hardware.
# success | fail_before_dispatch | timeout_before_dispatch | printer_not_found
# slow_execution | unknown_after_dispatch | crash_after_dispatch | success_then_ack_lost
FAKE_HARDWARE_SCENARIO=success
FAKE_LABEL_SCENARIO=
FAKE_DOCUMENT_SCENARIO=
FAKE_CASH_DRAWER_SCENARIO=
FAKE_HARDWARE_DELAY_MS=250
FAKE_HARDWARE_OUTPUT_DIR=./data/fake-output
# Optional: copy fake-plan.example.json lalu ubah path ini.
FAKE_HARDWARE_PLAN_PATH=./fake-plan.json
# Hanya untuk simulasi restart process nyata; default false agar developer tidak kehilangan terminal.
FAKE_EXIT_ON_CRASH=false

# Printer lokal Windows di Mini PC outlet. Wajib hanya ketika adapter device = real.
# Untuk raw SATO/cash drawer isi SHARE NAME printer Windows.
LABEL_PRINTER_NAME=SATO CG408TT
DOCUMENT_PRINTER_NAME=
CASH_DRAWER_PRINTER_NAME=

# Layout label SATO.
LABEL_PROFILE=jewelry_compact
LABEL_COPIES=1
LABEL_LEFT_OFFSET_DOTS=0
LABEL_TOP_OFFSET_DOTS=0
LABEL_INCLUDE_PRICE=false

# Silent PDF printing yang direkomendasikan: executable dan JSON argument array.
# Backslash dalam JSON harus ditulis biasa karena value berada di luar string JSON;
# hanya isi PDF_PRINT_ARGS_JSON yang merupakan JSON.
PDF_PRINT_EXECUTABLE=C:\Program Files\SumatraPDF\SumatraPDF.exe
PDF_PRINT_ARGS_JSON=["-print-to","{printer}","-silent","{file}"]

# Compatibility only. Jangan isi apabila memakai PDF_PRINT_EXECUTABLE.
# PDF_PRINT_COMMAND="C:\Program Files\SumatraPDF\SumatraPDF.exe" -print-to "{printer}" -silent "{file}"
PDF_PRINT_COMMAND=

POLL_INTERVAL_MS=2000
HEARTBEAT_INTERVAL_MS=30000
REQUEST_TIMEOUT_MS=15000
PRINT_COMMAND_TIMEOUT_MS=60000

# Production operations.
# Structured JSONL logs are rotated by date/size and pruned automatically.
HARDWARE_LOG_DIR=./logs
HARDWARE_LOG_LEVEL=info
HARDWARE_LOG_RETENTION_DAYS=30
HARDWARE_LOG_MAX_FILE_MB=20
HARDWARE_LOG_MAX_FILES=90
HARDWARE_LOG_PRUNE_INTERVAL_MS=3600000

# Single-instance process lock and local health diagnostics.
HARDWARE_LOCK_PATH=./data/agent.lock
HARDWARE_HEALTH_STATE_PATH=./data/health-state.json
HARDWARE_HEALTH_SERVER_ENABLED=true

# Security: must remain loopback only.
HARDWARE_HEALTH_SERVER_HOST=127.0.0.1
HARDWARE_HEALTH_SERVER_PORT=3210
HARDWARE_HEALTH_STALE_SECONDS=120
