{
  "name": "asihjaya-hardware-hub",
  "version": "0.7.0",
  "private": true,
  "description": "Local Hardware Hub agent for Asihjaya RMS Mini PC deployments.",
  "main": "agent.js",
  "engines": {
    "node": ">=22.5 <25"
  },
  "scripts": {
    "start": "node agent.js",
    "check": "node scripts/check-config.js",
    "check:dpapi": "node scripts/check-dpapi-hotfix.js",
    "install:startup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-startup-task.ps1 -RunNow",
    "uninstall:startup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-startup-task.ps1",
    "logs": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/open-logs.ps1",
    "check:v2": "node scripts/check-crash-safe-agent.js",
    "check:simulation": "node scripts/run-failure-injection-harness.js",
    "simulate:v2": "node scripts/run-failure-injection-harness.js --keep-output",
    "health": "node scripts/check-health.js",
    "status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/show-status.ps1",
    "support:bundle": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/export-support-bundle.ps1",
    "setup:production": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-production.ps1 -RunNow",
    "check:operations": "node scripts/check-production-operations.js",
    "check:print-profiles": "node scripts/check-document-print-profiles.js",
    "check:sato": "node scripts/check-sato-label-profiles.js",
    "update:golden:sato": "node scripts/check-sato-label-profiles.js --update-golden",
    "outlet:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/outlet-preflight.ps1",
    "outlet:fixtures": "node scripts/generate-outlet-fixtures.js",
    "outlet:test-sato-alignment": "node scripts/generate-outlet-fixtures.js",
    "outlet:test-epson-a4": "node scripts/generate-outlet-fixtures.js",
    "outlet:enable-real-label": "node scripts/outlet-adapter-switch.js --device label --mode real",
    "outlet:enable-real-document": "node scripts/outlet-adapter-switch.js --device document --mode real",
    "outlet:disable-real-hardware": "node scripts/outlet-adapter-switch.js --device all --mode fake",
    "outlet:rollback-to-fake": "node scripts/outlet-adapter-switch.js --device all --mode fake",
    "outlet:report": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-outlet-report.ps1",
    "check:outlet": "node scripts/check-outlet-readiness-pack.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
