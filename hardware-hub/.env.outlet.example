# ASIHJAYA Hardware Hub — Outlet Template
# Copy: Copy-Item .env.outlet.example .env
# Never commit the resulting .env.

# Local dev: http://localhost:3000
# Docker validation: http://localhost:3001
# Outlet production: HTTPS cloud URL
ASIHJAYA_API_URL=https://rms.example.com

# Create from the RMS project/dashboard. One identity per Mini PC.
HARDWARE_AGENT_ID=3282ca12-c278-409e-bd47-6648f72b97c1
HARDWARE_AGENT_SECRET=WE_yOT4d0NHE6PN3jaswEwuf_Ic0GeMxObFPwF7lKI7LKqc13GbLbfFxkZdbTJQ6
HARDWARE_PROTOCOL_MODE=v2-preferred

# Crash-safe local journal. Do not delete this file during troubleshooting.
HARDWARE_JOURNAL_PATH=./data/hardware-executions.sqlite
HARDWARE_JOURNAL_KEY_PATH=./data/hardware-journal.key
HARDWARE_POWERSHELL_EXECUTABLE=C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe
HARDWARE_TEMP_DIR=./data/temp
LEASE_RENEW_INTERVAL_MS=20000
LOCAL_RECOVERY_LIMIT=50

# SAFE DEFAULT: all fake. Activate one real device at a time with npm scripts.
HARDWARE_ADAPTER_MODE=real
LABEL_PRINTER_ADAPTER=real
DOCUMENT_PRINTER_ADAPTER=real
CASH_DRAWER_ADAPTER=fake

HARDWARE_DRY_RUN=false
FAKE_HARDWARE_SCENARIO=success
FAKE_LABEL_SCENARIO=
FAKE_DOCUMENT_SCENARIO=
FAKE_CASH_DRAWER_SCENARIO=
FAKE_HARDWARE_DELAY_MS=250
FAKE_HARDWARE_OUTPUT_DIR=./data/fake-output
FAKE_HARDWARE_PLAN_PATH=
FAKE_EXIT_ON_CRASH=false

# Exact Windows printer names from: Get-Printer
LABEL_PRINTER_NAME=SATO_CG408
DOCUMENT_PRINTER_NAME=EPSON L3250 Series
CASH_DRAWER_PRINTER_NAME=

# SATO CG408TT development profile. Tune only during physical acceptance.
LABEL_TEMPLATE_ID=jewelry_compact_v1
SATO_PRINTER_PROFILE=sato_cg408tt_jewelry_v1
SATO_COPIES=1
SATO_HORIZONTAL_OFFSET_DOTS=0
SATO_VERTICAL_OFFSET_DOTS=0
SATO_INCLUDE_PRICE=false
SATO_PRINT_SPEED=
SATO_DARKNESS=
SATO_MEDIA_WIDTH_DOTS=400
SATO_MEDIA_HEIGHT_DOTS=300

# Epson A4 deterministic SumatraPDF runner.
PDF_PRINT_EXECUTABLE=C:\Program Files\SumatraPDF\SumatraPDF.exe
PDF_PRINT_ARGS_JSON=
PDF_PRINT_COMMAND=

POLL_INTERVAL_MS=2000
HEARTBEAT_INTERVAL_MS=30000
REQUEST_TIMEOUT_MS=15000
PRINT_COMMAND_TIMEOUT_MS=60000

# Production operations.
HARDWARE_LOG_DIR=./logs
HARDWARE_LOG_LEVEL=info
HARDWARE_LOG_RETENTION_DAYS=30
HARDWARE_LOG_MAX_FILE_MB=20
HARDWARE_LOG_MAX_FILES=90
HARDWARE_LOG_PRUNE_INTERVAL_MS=3600000
HARDWARE_LOCK_PATH=./data/agent.lock
HARDWARE_HEALTH_STATE_PATH=./data/health-state.json
HARDWARE_HEALTH_SERVER_ENABLED=true
HARDWARE_HEALTH_SERVER_HOST=127.0.0.1
HARDWARE_HEALTH_SERVER_PORT=3210
HARDWARE_HEALTH_STALE_SECONDS=120
